{
  "name": "dp-vue2-widgets",
  "version": "1.0.1",
  "description": "",
  "main": "dist/dp-vue2-widgets.ssr.js",
  "browser": "dist/dp-vue2-widgets.esm.js",
  "module": "dist/dp-vue2-widgets.esm.js",
  "unpkg": "dist/dp-vue2-widgets.min.js",
  "scripts": {
    "serve": "vue-cli-service serve dev/serve.js",
    "prebuild": "rimraf ./dist",
    "dist:theme": "gulp build --gulpfile src/theme/theme-dp-ui/gulpfile.js && cp-cli src/theme/theme-dp-ui/lib dist/theme-dp-ui",
    "build": "cross-env NODE_ENV=production rollup --config build/rollup.config.js && npm run dist:theme",
    "build:ssr": "cross-env NODE_ENV=production rollup --config build/rollup.config.js --format cjs",
    "build:es": "cross-env NODE_ENV=production rollup --config build/rollup.config.js --format es",
    "build:unpkg": "cross-env NODE_ENV=production rollup --config build/rollup.config.js --format iife"
  },
  "repository": {
    "type": "git",
    "url": "http://172.16.180.219:9001/bigdata-platform/sixdatarepo/dp-vue2-widgets"
  },
  "keywords": [
    "UI 组件库",
    "数据平台部",
    "基于 element-ui"
  ],
  "author": "数据平台部",
  "devDependencies": {
    "@babel/core": "^7.14.6",
    "@babel/preset-env": "^7.14.7",
    "@rollup/plugin-alias": "^3.1.2",
    "@rollup/plugin-babel": "^5.3.0",
    "@rollup/plugin-commonjs": "^14.0.0",
    "@rollup/plugin-image": "^3.0.1",
    "@rollup/plugin-node-resolve": "^9.0.0",
    "@rollup/plugin-replace": "^2.4.2",
    "@vue/cli-plugin-babel": "^4.5.13",
    "@vue/cli-service": "^4.5.13",
    "cross-env": "^7.0.3",
    "element-ui": "^2.15.10",
    "gulp": "^4.0.2",
    "gulp-autoprefixer": "^6.0.0",
    "gulp-cssmin": "^0.2.0",
    "gulp-sass": "^5.1.0",
    "lodash": "^4.17.21",
    "minimist": "^1.2.5",
    "node-sass": "^6.0.1",
    "postcss": "^8.4.18",
    "postcss-url": "^10.1.3",
    "rimraf": "^3.0.2",
    "rollup": "^2.52.8",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-vue": "^5.1.9",
    "sass-loader": "^10.3.1",
    "vue": "^2.6.14",
    "vue-template-compiler": "^2.6.14"
  },
  "peerDependencies": {
    "vue": "^2.6.14"
  },
  "engines": {
    "node": ">=12"
  },
  "dependencies": {
    "cp-cli": "^2.0.0",
    "js-sha512": "^0.8.0",
    "vue-router": "^3.5.1"
  }
}
